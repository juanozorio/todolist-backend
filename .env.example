# ============================================================
# Task API - Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_ENV=development          # development | staging | production
APP_NAME=task-api            # used in structured logs

# --- HTTP Server ---
SERVER_PORT=8080             # port the API listens on
SERVER_READ_TIMEOUT=15s      # max time to read a request
SERVER_WRITE_TIMEOUT=15s     # max time to write a response

# --- PostgreSQL (all required) ---
DB_HOST=localhost            # postgres hostname
DB_PORT=5432                 # postgres port
DB_NAME=taskdb               # database name
DB_USER=taskuser             # database user
DB_PASSWORD=changeme         # database password  ← CHANGE THIS
DB_SSLMODE=disable           # disable | require | verify-full

# --- Connection Pool (optional, defaults shown) ---
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
